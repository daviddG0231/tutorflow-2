generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role
  createdAt     DateTime       @default(now())
  attendances   Attendance[]
  courses       Course[]
  enrollments   Enrollment[]
  notifications Notification[]
  quizGrades    QuizGrade[]
  submissions   Submission[]

  @@index([email])
  @@index([role])
}

model Course {
  id            String         @id @default(cuid())
  teacherId     String
  name          String
  description   String?
  location      String?
  courseCode    String         @unique
  createdAt     DateTime       @default(now())
  assignments   Assignment[]
  attendances   Attendance[]
  contents      Content[]
  teacher       User           @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  groups        CourseGroup[]
  enrollments   Enrollment[]
  modules       Module[]
  notifications Notification[]
  quizzes       Quiz[]

  @@index([teacherId])
  @@index([courseCode])
}

model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  courseId   String
  status     EnrollmentStatus @default(PENDING)
  enrolledAt DateTime         @default(now())
  groupId    String?
  course     Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  group      CourseGroup?     @relation(fields: [groupId], references: [id])
  student    User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
}

model Module {
  id        String    @id @default(cuid())
  courseId  String
  name      String
  order     Int       @default(0)
  createdAt DateTime  @default(now())
  contents  Content[]
  course    Course    @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([courseId, name])
  @@index([courseId])
}

model Content {
  id          String       @id @default(cuid())
  courseId    String
  title       String
  description String?
  fileUrl     String?
  fileType    FileType
  createdAt   DateTime     @default(now())
  groupId     String?
  moduleId    String?
  textContent String?
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  group       CourseGroup? @relation(fields: [groupId], references: [id])
  module      Module?      @relation(fields: [moduleId], references: [id])

  @@index([courseId])
  @@index([moduleId])
  @@index([groupId])
}

model Assignment {
  id            String       @id @default(cuid())
  courseId      String
  title         String
  description   String?
  attachmentUrl String?
  deadline      DateTime
  totalMarks    Int
  createdAt     DateTime     @default(now())
  groupId       String?
  course        Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  group         CourseGroup? @relation(fields: [groupId], references: [id])
  submissions   Submission[]

  @@index([courseId])
  @@index([groupId])
  @@index([deadline])
}

model Submission {
  id           String     @id @default(cuid())
  assignmentId String
  studentId    String
  fileUrl      String
  submittedAt  DateTime   @default(now())
  grade        Int?
  feedback     String?
  gradedAt     DateTime?
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student      User       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, studentId])
  @@index([assignmentId])
  @@index([studentId])
}

model Quiz {
  id         String       @id @default(cuid())
  courseId   String
  name       String
  totalMarks Int
  createdAt  DateTime     @default(now())
  groupId    String?
  course     Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  group      CourseGroup? @relation(fields: [groupId], references: [id])
  grades     QuizGrade[]

  @@index([courseId])
  @@index([groupId])
}

model QuizGrade {
  id        String   @id @default(cuid())
  quizId    String
  studentId String
  marks     Int
  gradedAt  DateTime @default(now())
  quiz      Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([quizId, studentId])
  @@index([quizId])
  @@index([studentId])
}

model Attendance {
  id        String           @id @default(cuid())
  courseId  String
  studentId String
  date      DateTime
  status    AttendanceStatus
  course    Course           @relation(fields: [courseId], references: [id], onDelete: Cascade)
  student   User             @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([courseId, studentId, date])
  @@index([courseId])
  @@index([studentId])
  @@index([date])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  courseId  String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  course    Course?  @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([courseId])
  @@index([read])
}

model CourseGroup {
  id          String       @id @default(cuid())
  courseId    String
  name        String
  createdAt   DateTime     @default(now())
  assignments Assignment[]
  contents    Content[]
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]
  quizzes     Quiz[]

  @@unique([courseId, name])
  @@index([courseId])
}

enum Role {
  TEACHER
  STUDENT
}

enum EnrollmentStatus {
  PENDING
  APPROVED
  REJECTED
}

enum FileType {
  VIDEO
  PDF
  SLIDE
  IMAGE
  DOCUMENT
  NOTE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}
